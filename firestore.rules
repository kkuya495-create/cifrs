rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow any authenticated (including anonymous) user to read and write
    // to the specified collections. This enables real-time collaboration.
    // This is more secure than a wildcard match.

    match /company/{profileId} {
      allow read, write: if request.auth != null;
    }

    match /accounts/{accountId} {
      allow read, write: if request.auth != null;
    }

    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }

    match /journal_entries/{journalEntryId} {
      allow read, write: if request.auth != null;
    }

    match /audit_logs/{auditLogId} {
      allow read, write: if request.auth != null;
    }

    match /items/{itemId} {
      allow read, write: if request.auth != null;
    }

    match /stock_cards/{stockCardId} {
      allow read, write: if request.auth != null;
    }
    
    match /products/{productId} {
      allow read, write: if request.auth != null;
    }
  }
}
